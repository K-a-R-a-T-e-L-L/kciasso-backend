datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

generator nestjsDto {
  provider                        = "prisma-generator-nestjs-dto"
  output                          = "../src/.generated/prisma"
  outputToNestJsResourceStructure = "true"
  flatResourceStructure           = "true"
  exportRelationModifierClasses   = "false"
  reExport                        = "true"
  generateFileTypes               = "all"
  createDtoPrefix                 = "Create"
  updateDtoPrefix                 = "Update"
  dtoSuffix                       = "Dto"
  entityPrefix                    = ""
  entitySuffix                    = ""
  classValidation                 = "true"
  fileNamingStyle                 = "camel"
  noDependencies                  = "false"
  outputType                      = "class"
  definiteAssignmentAssertion     = "false"
  requiredResponseApiProperty     = "true"
  prettier                        = "true"
  outputApiPropertyType           = "true"
}

model User {
  id                  Int                     @id @default(autoincrement())
  name                String
  /// @IsEmail
  email               String                  @unique
  password            String
  is_super_admin      Boolean                 @default(false)
  sessions            Session[]               @relation("UserSessions")
  section_permissions UserSectionPermission[] @relation("UserSectionPermissions")
  authored_news       News[]                  @relation("NewsAuthor")
  /// @DtoReadOnly
  created_at          DateTime                @default(now())
  /// @DtoReadOnly
  updated_at          DateTime                @updatedAt
  /// @DtoReadOnly
  deleted_at          DateTime?

  @@map("users")
}

model Session {
  id         Int       @id @default(autoincrement())
  token      String
  user_id    Int
  /// @DtoRelationRequired
  user       User      @relation("UserSessions", fields: [user_id], references: [id])
  expire_at  DateTime?
  /// @DtoReadOnly
  created_at DateTime  @default(now())
  /// @DtoReadOnly
  updated_at DateTime  @updatedAt
  /// @DtoReadOnly
  deleted_at DateTime?

  @@map("sessions")
}

model Section {
  id          Int                     @id @default(autoincrement())
  section_id  String                  @unique
  title       String
  kind        String
  route       String?
  parent_id   Int?
  sort_order  Int                     @default(0)
  is_editable Boolean                 @default(true)
  parent      Section?                @relation("SectionTree", fields: [parent_id], references: [id])
  children    Section[]               @relation("SectionTree")
  permissions UserSectionPermission[] @relation("SectionPermissions")
  /// @DtoReadOnly
  created_at  DateTime                @default(now())
  /// @DtoReadOnly
  updated_at  DateTime                @updatedAt
  /// @DtoReadOnly
  deleted_at  DateTime?

  @@map("sections")
}

model UserSectionPermission {
  id         Int       @id @default(autoincrement())
  user_id    Int
  section_id Int
  user       User      @relation("UserSectionPermissions", fields: [user_id], references: [id])
  section    Section   @relation("SectionPermissions", fields: [section_id], references: [id])
  /// @DtoReadOnly
  created_at DateTime  @default(now())
  /// @DtoReadOnly
  updated_at DateTime  @updatedAt
  /// @DtoReadOnly
  deleted_at DateTime?

  @@unique([user_id, section_id])
  @@map("user_section_permissions")
}

model NewsCategory {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String?
  order       Int      @default(0)
  is_active   Boolean  @default(true)
  news        News[]
  /// @DtoReadOnly
  created_at  DateTime @default(now())
  /// @DtoReadOnly
  updated_at  DateTime @updatedAt

  @@map("news_categories")
}

model News {
  id              Int           @id @default(autoincrement())
  slug            String        @unique
  title           String
  excerpt         String
  content         String
  cover_image_url String?
  published_at    DateTime?
  is_published    Boolean       @default(false)
  category_id     Int?
  author_id       Int?
  category        NewsCategory? @relation(fields: [category_id], references: [id])
  author          User?         @relation("NewsAuthor", fields: [author_id], references: [id])
  /// @DtoReadOnly
  created_at      DateTime      @default(now())
  /// @DtoReadOnly
  updated_at      DateTime      @updatedAt
  /// @DtoReadOnly
  deleted_at      DateTime?

  @@index([is_published, published_at])
  @@index([category_id])
  @@index([author_id])
  @@map("news")
}
