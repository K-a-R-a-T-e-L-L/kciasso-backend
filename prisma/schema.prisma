datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

generator nestjsDto {
  provider                        = "prisma-generator-nestjs-dto"
  output                          = "../src/.generated/prisma"
  outputToNestJsResourceStructure = "true"
  flatResourceStructure           = "true"
  exportRelationModifierClasses   = "false"
  reExport                        = "true"
  generateFileTypes               = "all"
  createDtoPrefix                 = "Create"
  updateDtoPrefix                 = "Update"
  dtoSuffix                       = "Dto"
  entityPrefix                    = ""
  entitySuffix                    = ""
  classValidation                 = "true"
  fileNamingStyle                 = "camel"
  noDependencies                  = "false"
  outputType                      = "class"
  definiteAssignmentAssertion     = "false"
  requiredResponseApiProperty     = "true"
  prettier                        = "true"
  outputApiPropertyType           = "true"
}

model User {
  id                  Int                     @id @default(autoincrement())
  name                String
  /// @IsEmail
  email               String                  @unique
  password            String
  is_super_admin      Boolean                 @default(false)
  sessions            Session[]               @relation("UserSessions")
  section_permissions UserSectionPermission[] @relation("UserSectionPermissions")
  authored_news       News[]                  @relation("NewsAuthor")
  created_documents   Document[]               @relation("DocumentCreatedBy")
  updated_documents   Document[]               @relation("DocumentUpdatedBy")
  created_document_versions DocumentVersion[]   @relation("DocumentVersionCreatedBy")
  created_document_share_links DocumentShareLink[] @relation("DocumentShareLinkCreatedBy")
  /// @DtoReadOnly
  created_at          DateTime                @default(now())
  /// @DtoReadOnly
  updated_at          DateTime                @updatedAt
  /// @DtoReadOnly
  deleted_at          DateTime?

  @@map("users")
}

model Session {
  id         Int       @id @default(autoincrement())
  token      String
  user_id    Int
  /// @DtoRelationRequired
  user       User      @relation("UserSessions", fields: [user_id], references: [id])
  expire_at  DateTime?
  /// @DtoReadOnly
  created_at DateTime  @default(now())
  /// @DtoReadOnly
  updated_at DateTime  @updatedAt
  /// @DtoReadOnly
  deleted_at DateTime?

  @@map("sessions")
}

model Section {
  id          Int                     @id @default(autoincrement())
  section_id  String                  @unique
  title       String
  kind        String
  route       String?
  parent_id   Int?
  sort_order  Int                     @default(0)
  is_editable Boolean                 @default(true)
  parent      Section?                @relation("SectionTree", fields: [parent_id], references: [id])
  children    Section[]               @relation("SectionTree")
  permissions UserSectionPermission[] @relation("SectionPermissions")
  /// @DtoReadOnly
  created_at  DateTime                @default(now())
  /// @DtoReadOnly
  updated_at  DateTime                @updatedAt
  /// @DtoReadOnly
  deleted_at  DateTime?

  @@map("sections")
}

model UserSectionPermission {
  id         Int       @id @default(autoincrement())
  user_id    Int
  section_id Int
  user       User      @relation("UserSectionPermissions", fields: [user_id], references: [id])
  section    Section   @relation("SectionPermissions", fields: [section_id], references: [id])
  /// @DtoReadOnly
  created_at DateTime  @default(now())
  /// @DtoReadOnly
  updated_at DateTime  @updatedAt
  /// @DtoReadOnly
  deleted_at DateTime?

  @@unique([user_id, section_id])
  @@map("user_section_permissions")
}

model NewsCategory {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String?
  order       Int      @default(0)
  is_active   Boolean  @default(true)
  news        News[]
  /// @DtoReadOnly
  created_at  DateTime @default(now())
  /// @DtoReadOnly
  updated_at  DateTime @updatedAt

  @@map("news_categories")
}

model News {
  id              Int           @id @default(autoincrement())
  slug            String        @unique
  title           String
  excerpt         String
  content         String
  cover_image_url String?
  published_at    DateTime?
  is_published    Boolean       @default(false)
  category_id     Int?
  author_id       Int?
  category        NewsCategory? @relation(fields: [category_id], references: [id])
  author          User?         @relation("NewsAuthor", fields: [author_id], references: [id])
  /// @DtoReadOnly
  created_at      DateTime      @default(now())
  /// @DtoReadOnly
  updated_at      DateTime      @updatedAt
  /// @DtoReadOnly
  deleted_at      DateTime?

  @@index([is_published, published_at])
  @@index([category_id])
  @@index([author_id])
  @@map("news")
}

model SiteSettings {
  id                String   @id @default(uuid())
  site_key          String   @unique
  gia_hotline_phone String
  information_phone String
  ege_trust_phone   String
  email             String
  home_sections_order String[] @default(["home.quick-access", "home.resources", "home.gia-reference", "home.official-resources"])
  /// @DtoReadOnly
  created_at        DateTime @default(now())
  /// @DtoReadOnly
  updated_at        DateTime @updatedAt

  @@map("site_settings")
}

enum DocumentStatus {
  DRAFT
  UNLISTED
  PUBLISHED
  ARCHIVED
}

model Document {
  id                Int              @id @default(autoincrement())
  section_key       String
  title             String
  description       String?
  document_number   String?
  document_date     DateTime?
  status            DocumentStatus   @default(DRAFT)
  sort_order        Int              @default(0)
  current_version_id Int?             @unique
  created_by_id     Int?
  updated_by_id     Int?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  deleted_at        DateTime?
  versions          DocumentVersion[] @relation("DocumentVersions")
  current_version   DocumentVersion?  @relation("DocumentCurrentVersion", fields: [current_version_id], references: [id], onDelete: Restrict)
  created_by        User?            @relation("DocumentCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)
  updated_by        User?            @relation("DocumentUpdatedBy", fields: [updated_by_id], references: [id], onDelete: SetNull)
  placements        DocumentPlacement[]

  @@index([section_key, status, sort_order])
  @@index([section_key, deleted_at])
  @@map("documents")
}

model DocumentPlacement {
  id          Int      @id @default(autoincrement())
  document_id Int
  section_key String
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  document    Document @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@unique([document_id, section_key])
  @@index([section_key, sort_order, document_id])
  @@map("document_placements")
}

model DocumentVersion {
  id             Int       @id @default(autoincrement())
  document_id    Int
  version_number Int
  storage_key    String    @unique
  original_filename String
  extension      String
  mime_type      String
  size_bytes     BigInt
  sha256         String
  created_by_id  Int?
  created_at     DateTime  @default(now())
  document       Document  @relation("DocumentVersions", fields: [document_id], references: [id], onDelete: Restrict)
  current_for    Document? @relation("DocumentCurrentVersion")
  created_by     User?     @relation("DocumentVersionCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)
  share_links    DocumentShareLink[] @relation("DocumentVersionShareLinks")

  @@unique([document_id, version_number])
  @@unique([document_id, sha256])
  @@index([document_id, created_at])
  @@map("document_versions")
}

model DocumentShareLink {
  id                  Int             @id @default(autoincrement())
  document_version_id Int
  token_hash          String          @unique
  token_prefix        String
  expires_at          DateTime?
  revoked_at          DateTime?
  created_by_id       Int?
  created_at          DateTime        @default(now())
  last_access_at      DateTime?
  access_count        Int             @default(0)
  document_version    DocumentVersion @relation("DocumentVersionShareLinks", fields: [document_version_id], references: [id], onDelete: Restrict)
  created_by          User?           @relation("DocumentShareLinkCreatedBy", fields: [created_by_id], references: [id], onDelete: SetNull)

  @@index([document_version_id])
  @@index([revoked_at, expires_at])
  @@index([created_at])
  @@map("document_share_links")
}
