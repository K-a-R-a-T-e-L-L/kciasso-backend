NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kciasso_backend_dev?schema=public
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_PORT_OUT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_DB=kciasso_backend_dev
JWT_SECRET=change-me-secret
JWT_EXPIRES=365d
SERVICE_TOKEN_AUTH=change-me-service-token
UPLOADS_DIR=./uploads
PUBLIC_UPLOADS_URL=/uploads
DOCUMENT_STORAGE_ROOT=./storage/documents
DOCUMENT_TEMP_ROOT=./storage/tmp
DOCUMENT_MAX_FILE_SIZE_MB=50
NEWS_MEDIA_ROOT=./storage/media/news
FRONTEND_URL=http://localhost:3000
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
# SUPER_ADMIN_PASSWORD should contain at least 8 characters.
